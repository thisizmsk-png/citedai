{
  "name": "citedai",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate --filter=@citedai/db",
    "db:migrate": "turbo db:migrate --filter=@citedai/db",
    "db:push": "turbo db:push --filter=@citedai/db",
    "db:studio": "pnpm --filter @citedai/db drizzle-kit studio",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
